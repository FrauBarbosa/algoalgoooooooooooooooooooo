<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Embassy of Nepal in Brazil</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background-color: #f4f4f4;
}

/* HEADER */
header {
  background: #b22222;
  color: white;
  padding: 20px;
  text-align: center;
}

header h1 {
  margin: 0;
}

header p {
  margin: 5px;
}

/* NAVBAR */
nav {
  background: #003893;
  padding: 10px;
  text-align: center;
}

nav a {
  color: white;
  margin: 0 20px;
  text-decoration: none;
  font-weight: bold;
}

nav a:hover {
  text-decoration: underline;
}

/* HERO */
.hero {
  background: url('https://upload.wikimedia.org/wikipedia/commons/1/12/Mount_Everest_as_seen_from_Drukair2_PLW_edit.jpg') center/cover;
  color: white;
  text-align: center;
  padding: 80px 20px;
}

.hero h2 {
  font-size: 32px;
}

/* CONTAINER */
.container {
  padding: 30px;
}

/* CARDS */
.card {
  background: white;
  padding: 20px;
  margin-bottom: 20px;
  border-left: 6px solid #b22222;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

/* BUTTON */
.btn {
  display: inline-block;
  padding: 10px 15px;
  background: #003893;
  color: white;
  text-decoration: none;
  border-radius: 5px;
  margin-top: 10px;
}

.btn:hover {
  background: #002060;
}

/* FOOTER */
footer {
  background: #111;
  color: white;
  text-align: center;
  padding: 15px;
}
</style>

</head>

<body>

<header>
  <h1>Embassy of Nepal in Brazil</h1>
  <p>Official Diplomatic Mission</p>
</header>

<nav>
  <a href="#home">Home</a>
  <a href="#services">Services</a>
  <a href="#about">About</a>
  <a href="#contact">Contact</a>
</nav>

<section class="hero">
  <h2>Welcome to the Embassy of Nepal</h2>
  <p>Strengthening Nepal–Brazil Relations</p>
</section>

<div class="container">

  <div class="card" id="home">
    <h2>Welcome</h2>
    <p>The Embassy of Nepal in Brazil provides consular services, promotes bilateral relations, and supports Nepali citizens and Brazilian visitors.</p>
  </div>

  <div class="card" id="services">
    <h2>Consular Services</h2>
    <ul>
      <li>Visa Application</li>
      <li>Passport Services</li>
      <li>Document Authentication</li>
    </ul>
    <a class="btn" href="#contact">Start Application</a>
  </div>

  <div class="card" id="about">
    <h2>About the Embassy</h2>
    <p>The Embassy works to strengthen diplomatic, economic, and cultural relations between Nepal and Brazil.</p>
  </div>

  <div class="card" id="contact">
    <h2>Contact</h2>
    <p><strong>Ambassador:</strong> Nirmal Raj Kafle</p>
    <p>Email: info@nepalembassy.gov.np</p>
    <p>Location: Brasília, Brazil</p>
  </div>

</div>

<footer>
  <p>© 2026 Embassy of Nepal in Brazil</p>
</footer>

</body>
</html>
<a class="btn" href="#contact">Start Application</a>
<h2>Contact / Contato</h2>
<p>Email: info@nepalembassy.gov.np</p>
<p><strong>Official Diplomatic Mission</strong></p>
